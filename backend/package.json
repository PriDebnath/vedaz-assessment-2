{
  "name": "backend",
  "version": "1.0.50",
  "scripts": {
    "dev": "nodemon --legacy-watch --watch src --ext ts,json --exec ts-node --files src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down -v",
    "db:generate": "npx drizzle-kit generate --config=./src/drizzle.config.ts",
    "db:migrate": "npx drizzle-kit migrate --config=./src/drizzle.config.ts",
    "db:studio": "npx drizzle-kit studio --config=./src/drizzle.config.ts"
  },
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.16.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "autocannon": "^8.0.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.10",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "eslint": "^9.39.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "nodemon": "^3.1.14",
    "pg": "^8.22.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prom-client": "^15.1.3",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.9.3",
    "zod": "^4.3.6"
  },
